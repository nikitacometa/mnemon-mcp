{
  "name": "mnemon-mcp",
  "version": "1.0.0",
  "description": "Persistent layered memory MCP server for AI agents — SQLite + FTS5 backend",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "import:kb": "tsx src/import/cli.ts --kb-path ${MNEMON_KB_PATH:-.}",
    "test": "vitest run",
    "db:backup": "bash -c \"sqlite3 $HOME/.mnemon-mcp/memory.db '.backup $HOME/.mnemon-mcp/memory.db.bak' && echo 'Backup saved to ~/.mnemon-mcp/memory.db.bak'\""
  },
  "keywords": [
    "mcp",
    "memory",
    "sqlite",
    "ai-agent"
  ],
  "author": "nikitacometa",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.6.2",
    "snowball-stemmer.jsx": "^0.2.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
